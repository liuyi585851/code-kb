# Code-KB P1 环境配置

CODEKB_ENV=dev
CODEKB_REGISTRY=docs/kb-registry.draft.yaml
CODEKB_FIXTURES=data/fixtures/sample_corpus.jsonl
CODEKB_ALIASES=data/entity_aliases.yaml
CODEKB_RETRIEVER=bm25-lite
CODEKB_INDEX_DB=/data/codekb/local-index/codekb.sqlite3
CODEKB_ENV_FILE=/data/codekb/state/p5-secrets.env

# API
CODEKB_HOST=0.0.0.0
CODEKB_PORT=8080
CODEKB_TRACE_LOG=/data/codekb/logs/ask-trace.jsonl
CODEKB_FEEDBACK_LOG=/data/codekb/logs/feedback.jsonl
CODEKB_SYNC_STATE=/data/codekb/state/wiki-sync-state.json
CODEKB_SYNC_REPORT=/data/codekb/logs/wiki-sync-report.json
CODEKB_CANDIDATE_STORE=/data/codekb/state/candidates.json
CODEKB_PENDING_DOCS_DIR=/data/codekb/pending-docs
CODEKB_DIAGNOSE_WEBHOOK_TOKEN=
CODEKB_DIAGNOSE_WEBHOOK_SAMPLES=docs/diagnose-webhook-samples.draft.yaml
CODEKB_DIAGNOSE_WEBHOOK_REAL_SAMPLES=/data/codekb/state/diagnose-webhook-samples.real.yaml
CODEKB_PUBLISH_OUTBOX=/data/codekb/outbox/wiki-publish-plan.jsonl
CODEKB_PUBLISH_REPORT=/data/codekb/logs/wiki-publish-report.json
CODEKB_GOVERNANCE_REPORT=/data/codekb/logs/governance-report.json
CODEKB_GOVERNANCE_POLICY=docs/governance-policy.draft.yaml
CODEKB_GOVERNANCE_STATE=/data/codekb/state/governance-state.json
CODEKB_GOVERNANCE_WEEKLY_REPORT=/data/codekb/logs/governance-weekly-report.md
CODEKB_GOVERNANCE_TICKET_OUTBOX=/data/codekb/outbox/governance-ticket-plan.jsonl
CODEKB_GOVERNANCE_TICKET_REPORT=/data/codekb/logs/governance-ticket-report.json
CODEKB_ENABLE_GOVERNANCE_WRITE=0
CODEKB_ENABLE_WIKI_WRITE=0
CODEKB_AUTH_ADMIN_TOKEN=
CODEKB_USER_TOKEN_STORE=/data/codekb/state/user-tokens.json
CODEKB_USER_CONFIRMATION_OUTBOX=/data/codekb/outbox/user-confirmation.jsonl
CODEKB_USER_CONFIRMATION_REPORT=/data/codekb/logs/user-confirmation-report.json
CODEKB_USER_CONFIRMATION_RESPONSES=/data/codekb/state/user-confirmation-responses.jsonl
CODEKB_USER_CONFIRMATION_DELIVERY_LOG=/data/codekb/state/user-confirmation-delivery.jsonl
CODEKB_USER_AUTH_TOKEN=
CODEKB_ENABLE_IM_SEND=0
CODEKB_CONFIRMATION_WORKER_INTERVAL=15
CODEKB_CONFIRMATION_WORKER_EXECUTE=0
CODEKB_IM_CORP_ID=
CODEKB_IM_AGENT_ID=
CODEKB_IM_APP_SECRET=
CODEKB_IM_API_BASE=https://im-api.example.com/cgi-bin
CODEKB_IM_CONFIRM_URL_BASE=
CODEKB_IM_OAUTH_AUTHORIZE_BASE=https://im-oauth.example.com/connect/oauth2/authorize
CODEKB_IM_OAUTH_REDIRECT_URI=
CODEKB_IM_OAUTH_SCOPE=snsapi_base
CODEKB_IM_OAUTH_STATE_SECRET=
CODEKB_IM_OAUTH_TOKEN_TTL_DAYS=30

# Postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=codekb
POSTGRES_USER=codekb
POSTGRES_PASSWORD=change-me

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=codekb_atoms

# Elasticsearch / OpenSearch
ES_URL=http://127.0.0.1:9200
ES_INDEX=codekb_atoms

# 模型服务在 P1 基线里是可选的。
EMBEDDING_ENDPOINT=
RERANKER_ENDPOINT=
LLM_ENDPOINT=

# 生成式回答层(可选)。默认走确定性的抽取式基线;只有装了 `pip install .[llm]`
# 并配好真实 key 才切到生成式,否则回答链路会自动降级回抽取式。
CODEKB_ANSWER_MODE=extractive
# 生成器 LLM(见 docs/p0-dependencies.md:一个 OpenAI 兼容模型 / 团队代理)。
# 默认 provider 'openai_compat' 指向 OpenAI 的 chat/completions 端点
# (团队模型代理、OpenAI 兼容端点等)。LLM_API_KEY 要放在真实的环境
# /密钥库里 —— 绝不要提交进仓库。
CODEKB_LLM_PROVIDER=openai_compat
CODEKB_LLM_ENDPOINT=http://llm-proxy.example.com/v1/chat/completions
CODEKB_LLM_API_KEY=
CODEKB_LLM_MODEL=deepseek-v4-flash-r1
# temperature=0 —— 推理模型靠它(配合 prompt 里的示例)才能稳定输出
# 行内 [n] 引用,满足 cite-or-die 校验的要求。
CODEKB_LLM_TEMPERATURE=0
CODEKB_LLM_MAX_TOKENS=16000
CODEKB_LLM_TIMEOUT=30
# 另一种 provider:设 CODEKB_LLM_PROVIDER=anthropic 并安装 .[llm]
ANTHROPIC_API_KEY=

# 可选:检索前用 LLM 做查询扩展(自然语言/中文概念 -> 代码标识符)。需要 LLM。
CODEKB_QUERY_EXPANSION=0
