#!/usr/bin/env bash
set -euo pipefail

BOOTSTRAP_RUN_DIR="${CODEKB_RUN_DIR:-/data/codekb}"
ENV_FILE="${CODEKB_ENV_FILE:-$BOOTSTRAP_RUN_DIR/state/p5-secrets.env}"
if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  set +a
fi

APP_ROOT="${CODEKB_APP_ROOT:-/data/codekb/current}"
VENV="${CODEKB_VENV:-/data/codekb/venv}"
RUN_DIR="${CODEKB_RUN_DIR:-$BOOTSTRAP_RUN_DIR}"
LOG_DIR="${CODEKB_LOG_DIR:-/data/codekb/logs}"
OUTBOX="${CODEKB_USER_CONFIRMATION_OUTBOX:-$RUN_DIR/outbox/user-confirmation.jsonl}"
TOKEN_STORE="${CODEKB_USER_TOKEN_STORE:-$RUN_DIR/state/user-tokens.json}"
REPORT="${CODEKB_USER_CONFIRMATION_REPORT:-$LOG_DIR/user-confirmation-report.json}"
DELIVERY_LOG="${CODEKB_USER_CONFIRMATION_DELIVERY_LOG:-$RUN_DIR/state/user-confirmation-delivery.jsonl}"
PID_FILE="${CODEKB_CONFIRMATION_WORKER_PID_FILE:-$RUN_DIR/confirmation-worker.pid}"
LOG_FILE="${CODEKB_CONFIRMATION_WORKER_LOG_FILE:-$LOG_DIR/confirmation-worker.log}"
INTERVAL="${CODEKB_CONFIRMATION_WORKER_INTERVAL:-15}"
LIMIT="${CODEKB_CONFIRMATION_WORKER_LIMIT:-50}"
EXECUTE="${CODEKB_CONFIRMATION_WORKER_EXECUTE:-${CODEKB_ENABLE_IM_SEND:-0}}"

is_running() {
  [[ -s "$PID_FILE" ]] || return 1
  local pid
  pid="$(cat "$PID_FILE")"
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

worker_args() {
  local args=(
    user-confirmation-outbox
    --outbox "$OUTBOX"
    --token-store "$TOKEN_STORE"
    --report "$REPORT"
    --delivery-log "$DELIVERY_LOG"
    --limit "$LIMIT"
    --json
  )
  if [[ "$EXECUTE" == "1" ]]; then
    args+=(--execute)
  fi
  printf '%s\n' "${args[@]}"
}

run_once() {
  mkdir -p "$RUN_DIR" "$LOG_DIR" "$(dirname "$OUTBOX")" "$(dirname "$TOKEN_STORE")" "$(dirname "$REPORT")" "$(dirname "$DELIVERY_LOG")"
  cd "$APP_ROOT"
  mapfile -t args < <(worker_args)
  PYTHONPATH="$APP_ROOT/src" "$VENV/bin/python" -m codekb "${args[@]}"
}

loop() {
  while true; do
    if ! run_once; then
      echo "confirmation worker iteration failed" >&2
    fi
    sleep "$INTERVAL"
  done
}

start() {
  if is_running; then
    echo "codekb-confirmation-worker already running pid=$(cat "$PID_FILE")"
    return 0
  fi
  mkdir -p "$RUN_DIR" "$LOG_DIR" "$(dirname "$PID_FILE")"
  nohup "$0" loop >> "$LOG_FILE" 2>&1 &
  echo "$!" > "$PID_FILE"
  sleep 1
  if ! is_running; then
    echo "codekb-confirmation-worker failed to start; see $LOG_FILE" >&2
    return 1
  fi
  echo "codekb-confirmation-worker started pid=$(cat "$PID_FILE") interval=$INTERVAL execute=$EXECUTE"
}

stop() {
  if ! is_running; then
    echo "codekb-confirmation-worker not running"
    rm -f "$PID_FILE"
    return 0
  fi
  local pid
  pid="$(cat "$PID_FILE")"
  kill "$pid"
  for _ in $(seq 1 20); do
    if ! kill -0 "$pid" 2>/dev/null; then
      rm -f "$PID_FILE"
      echo "codekb-confirmation-worker stopped"
      return 0
    fi
    sleep 0.5
  done
  echo "codekb-confirmation-worker did not stop within timeout pid=$pid" >&2
  return 1
}

status() {
  if is_running; then
    echo "codekb-confirmation-worker running pid=$(cat "$PID_FILE") interval=$INTERVAL execute=$EXECUTE"
  else
    echo "codekb-confirmation-worker stopped"
    return 1
  fi
}

case "${1:-}" in
  once)
    run_once
    ;;
  loop)
    loop
    ;;
  start)
    start
    ;;
  stop)
    stop
    ;;
  restart)
    stop
    start
    ;;
  status)
    status
    ;;
  *)
    echo "usage: $0 {once|start|stop|restart|status}" >&2
    exit 2
    ;;
esac
